#!/usr/bin/env bash
#
# Domainization Pre-Commit Hook (OPTIONAL, OBSERVABILITY MODE)
#
# This hook provides observability into domainization governance.
# It NEVER blocks commits - it only displays warnings and suggestions.
#
# Installation: Run .domainization/hooks/install_hook.sh
# Bypass: Use --no-verify flag (no audit needed since hook never blocks)
#

set -e

# Colors for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Get repository root
REPO_ROOT=$(git rev-parse --show-toplevel)
DOMAINIZATION_DIR="$REPO_ROOT/.domainization"
PYTHON_SRC="$DOMAINIZATION_DIR/src"

# Check if domainization system exists
if [ ! -d "$DOMAINIZATION_DIR" ]; then
    echo -e "${YELLOW}⚠ Domainization system not found. Skipping validation.${NC}"
    exit 0
fi

# Check if Python source exists
if [ ! -d "$PYTHON_SRC" ]; then
    echo -e "${YELLOW}⚠ Domainization Python modules not found. Skipping validation.${NC}"
    exit 0
fi

echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${BLUE}Domainization Observability Check${NC}"
echo -e "${BLUE}Mode: WARNINGS ONLY (commit will proceed regardless)${NC}"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""

# Get list of changed files (staged for commit)
CHANGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$CHANGED_FILES" ]; then
    echo -e "${GREEN}✓ No files staged for commit.${NC}"
    exit 0
fi

echo -e "${BLUE}Changed files:${NC}"
echo "$CHANGED_FILES" | while read -r file; do
    echo "  - $file"
done
echo ""

# Create temporary file for changed files list
TEMP_FILE=$(mktemp)
echo "$CHANGED_FILES" > "$TEMP_FILE"

# Run Python validation orchestrator
echo -e "${BLUE}Running validation observers...${NC}"
echo ""

# Change to Python source directory and run validation
cd "$PYTHON_SRC"

# Run validation script (use project venv if available, fallback to python3)
PYTHON_CMD="python3"
if [ -f "$REPO_ROOT/.venv/bin/python" ]; then
    PYTHON_CMD="$REPO_ROOT/.venv/bin/python"
fi

$PYTHON_CMD - "$TEMP_FILE" "$REPO_ROOT" <<'PYTHON_SCRIPT'
import sys
from pathlib import Path

# Get arguments
changed_files_path = sys.argv[1]
repo_root = Path(sys.argv[2])

# Read changed files
with open(changed_files_path, 'r') as f:
    changed_files = [repo_root / line.strip() for line in f if line.strip()]

# Import validation modules
try:
    from artifact_registry import ArtifactRegistry
    from domain_registry import DomainRegistry
    from lifecycle_manager import LifecycleManager
    from validation_orchestrator import ValidationOrchestrator
except ImportError as e:
    print(f"⚠ Could not import validation modules: {e}")
    print("Skipping validation.")
    sys.exit(0)

# Initialize registries
try:
    artifact_registry = ArtifactRegistry(repo_root / ".domainization" / "artifact_registry.yaml")
    domain_registry = DomainRegistry(repo_root / ".domainization" / "domain_registry.yaml")
    lifecycle_manager = LifecycleManager(repo_root / ".domainization" / "lifecycle_state_machine.yaml")
except Exception as e:
    print(f"⚠ Could not load registries: {e}")
    print("Skipping validation.")
    sys.exit(0)

# Create orchestrator
orchestrator = ValidationOrchestrator(
    artifact_registry=artifact_registry,
    domain_registry=domain_registry,
    lifecycle_manager=lifecycle_manager,
    repo_root=repo_root
)

# Run validation
try:
    report = orchestrator.validate_all(changed_files=changed_files if changed_files else None)
    print(report)
except Exception as e:
    print(f"⚠ Validation failed with error: {e}")
    print("Skipping validation.")
    sys.exit(0)

# Always exit 0 (never block commit)
sys.exit(0)
PYTHON_SCRIPT

VALIDATION_EXIT_CODE=$?

# Clean up temporary file
rm -f "$TEMP_FILE"

# Always exit 0 (never block commit)
echo ""
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

if [ $VALIDATION_EXIT_CODE -eq 0 ]; then
    echo -e "${GREEN}✓ Observability check complete. Commit proceeding.${NC}"
else
    echo -e "${YELLOW}⚠ Observability check encountered issues. Commit proceeding anyway.${NC}"
fi

echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""

# Always exit 0 (never block commit)
exit 0
